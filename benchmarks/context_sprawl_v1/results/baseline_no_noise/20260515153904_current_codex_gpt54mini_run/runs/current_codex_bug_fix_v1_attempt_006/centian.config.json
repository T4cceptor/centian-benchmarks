{
  "name": "Context Sprawl v1",
  "version": "1.0.0",
  "proxy": {
    "host": "127.0.0.1",
    "port": "57158",
    "logLevel": "debug",
    "logOutput": "file",
    "logFile": "benchmarks/context_sprawl_v1/results/baseline_no_noise/20260515153904_current_codex_run/runs/current_codex_bug_fix_v1_attempt_006/logs/internal.log",
    "timeout": 30
  },
  "projects": {
    "default": {
      "slug": "default",
      "auth": false,
      "capabilities": {
        "taskVerification": {
          "enabled": true,
          "templatesPath": "benchmarks/context_sprawl_v1/results/baseline_no_noise/20260515153904_current_codex_run/runs/current_codex_bug_fix_v1_attempt_006/.runtime/templates"
        },
        "eventStorage": {
          "enabled": true,
          "driver": "sqlite",
          "path": "./benchmarks/context_sprawl_v1/results/context_sprawl_v1.sqlite"
        },
        "ui": {
          "enabled": true
        }
      },
      "gateways": {
        "taskverification": {
          "setupGateway": true,
          "forceReadOnlyHints": true,
          "forceSafeToolHints": true,
          "verificationRequirement": "required",
          "mcpServers": {
            "docs": {
              "name": "",
              "command": "node",
              "args": [
                "./benchmarks/context_sprawl_v1/server/get_docs_server.mjs"
              ],
              "env": {
                "CONTEXT_SPRAW_PROFILE": "baseline"
              },
              "enabled": true,
              "description": "Mock MyOrgAPI documentation server exposing get_docs."
            },
            "filesystem": {
              "name": "",
              "command": "npx",
              "args": [
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "benchmarks/context_sprawl_v1/results/baseline_no_noise/20260515153904_current_codex_run/runs/current_codex_bug_fix_v1_attempt_006/project"
              ],
              "enabled": true,
              "description": "Filesystem access to the context-sprawl workspace."
            },
            "shell": {
              "name": "",
              "command": "npx",
              "args": [
                "-y",
                "shell-command-mcp"
              ],
              "env": {
                "ALLOWED_COMMANDS": "*"
              },
              "enabled": true,
              "description": "Shell access for the context-sprawl benchmark."
            }
          }
        }
      }
    }
  }
}